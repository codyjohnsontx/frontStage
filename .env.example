# Copy to .env (root) and packages/database/.env as needed. Never commit real secrets.

# Local development database (matches docker-compose.yml)
DATABASE_URL="postgresql://frontstage:frontstage_dev@localhost:5434/frontstage"

# Local email capture (Mailpit)
SMTP_HOST="localhost"
SMTP_PORT="1025"

# OAuth (Phase 0 web app — fill in from Google/Microsoft consoles)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
MICROSOFT_CLIENT_ID=""
MICROSOFT_CLIENT_SECRET=""

# Auth session secret (generate with: openssl rand -base64 32)
AUTH_SECRET=""
