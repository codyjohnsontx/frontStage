// Frontstage Phase 0 schema: identity, tenancy, scoped authorization,
// invitations, audit, outbox, jobs, feature flags, idempotency.
//
// Domain boundaries follow docs/domain-model.md. Client organizations,
// portals, projections, deliverables, etc. arrive in Phase 1+ — this file
// deliberately contains only what Phase 0 exit criteria require.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------------------------------------------------------------------------
// Identity
// ---------------------------------------------------------------------------

model User {
  id        String   @id @default(uuid()) @db.Uuid
  email     String   @unique
  name      String?
  avatarUrl String?  @map("avatar_url")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  authAccounts        AuthAccount[]
  sessions            Session[]
  memberships         OrganizationMembership[]
  portalMemberships   PortalMembership[]
  clientRequests      ClientRequest[]
  requestsDecided     ClientRequest[]          @relation("RequestDecider")
  requestMessages     RequestMessage[]
  invitationsSent     Invitation[]             @relation("InvitationInviter")
  invitationsAccepted Invitation[]             @relation("InvitationAcceptor")

  @@map("users")
}

enum AuthProvider {
  GOOGLE
  MICROSOFT

  @@map("auth_provider")
}

model AuthAccount {
  id                String       @id @default(uuid()) @db.Uuid
  userId            String       @map("user_id") @db.Uuid
  provider          AuthProvider
  providerAccountId String       @map("provider_account_id")
  createdAt         DateTime     @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("auth_accounts")
}

model Session {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  tokenHash String   @unique @map("token_hash")
  expiresAt DateTime @map("expires_at")
  ipAddress String?  @map("ip_address")
  userAgent String?  @map("user_agent")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("sessions")
}

// ---------------------------------------------------------------------------
// Tenancy
// ---------------------------------------------------------------------------

model Organization {
  id        String    @id @default(uuid()) @db.Uuid
  name      String
  slug      String    @unique
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  memberships        OrganizationMembership[]
  invitations        Invitation[]
  auditEvents        AuditEvent[]
  idempotencyRecords IdempotencyRecord[]

  @@map("organizations")
}

enum MembershipStatus {
  ACTIVE
  SUSPENDED

  @@map("membership_status")
}

model OrganizationMembership {
  id             String           @id @default(uuid()) @db.Uuid
  organizationId String           @map("organization_id") @db.Uuid
  userId         String           @map("user_id") @db.Uuid
  status         MembershipStatus @default(ACTIVE)
  createdAt      DateTime         @default(now()) @map("created_at")
  updatedAt      DateTime         @updatedAt @map("updated_at")

  organization    Organization         @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user            User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  roleAssignments ScopedRoleAssignment[]

  @@unique([organizationId, userId])
  @@index([userId])
  @@map("organization_memberships")
}

// ---------------------------------------------------------------------------
// Authorization
//
// Role definitions (role -> permission bundles) live in code in
// @frontstage/authorization (see docs/adr/0003). The database stores WHO has
// WHICH role at WHAT scope. Custom roles later become a table without
// changing this shape.
// ---------------------------------------------------------------------------

enum RoleKey {
  ORGANIZATION_OWNER
  ORGANIZATION_ADMIN
  PORTAL_ADMIN
  PROJECT_LEAD
  CONTRIBUTOR
  INTERNAL_VIEWER
  CLIENT_ADMIN
  CLIENT_APPROVER
  CLIENT_CONTRIBUTOR
  CLIENT_VIEWER

  @@map("role_key")
}

enum ScopeType {
  ORGANIZATION
  CLIENT_ORGANIZATION
  PORTAL
  PROJECT

  @@map("scope_type")
}

model ScopedRoleAssignment {
  id             String    @id @default(uuid()) @db.Uuid
  organizationId String    @map("organization_id") @db.Uuid
  membershipId   String    @map("membership_id") @db.Uuid
  roleKey        RoleKey   @map("role_key")
  scopeType      ScopeType @map("scope_type")
  // Null for ORGANIZATION scope; otherwise the client org / portal / project id.
  scopeId        String?   @map("scope_id") @db.Uuid
  grantedById    String?   @map("granted_by_id") @db.Uuid
  createdAt      DateTime  @default(now()) @map("created_at")

  membership OrganizationMembership @relation(fields: [membershipId], references: [id], onDelete: Cascade)

  @@unique([membershipId, roleKey, scopeType, scopeId])
  @@index([organizationId])
  @@map("scoped_role_assignments")
}

// ---------------------------------------------------------------------------
// Invitations — email-bound, single-use, expiring, revocable, audited.
// ---------------------------------------------------------------------------

enum InvitationStatus {
  PENDING
  ACCEPTED
  REVOKED
  EXPIRED

  @@map("invitation_status")
}

model Invitation {
  id             String           @id @default(uuid()) @db.Uuid
  organizationId String           @map("organization_id") @db.Uuid
  email          String
  roleKey        RoleKey          @map("role_key")
  scopeType      ScopeType        @map("scope_type")
  scopeId        String?          @map("scope_id") @db.Uuid
  tokenHash      String           @unique @map("token_hash")
  status         InvitationStatus @default(PENDING)
  expiresAt      DateTime         @map("expires_at")
  invitedById    String           @map("invited_by_id") @db.Uuid
  acceptedById   String?          @map("accepted_by_id") @db.Uuid
  acceptedAt     DateTime?        @map("accepted_at")
  revokedAt      DateTime?        @map("revoked_at")
  createdAt      DateTime         @default(now()) @map("created_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  invitedBy    User         @relation("InvitationInviter", fields: [invitedById], references: [id])
  acceptedBy   User?        @relation("InvitationAcceptor", fields: [acceptedById], references: [id])

  @@index([organizationId, status])
  @@index([email])
  @@map("invitations")
}

// ---------------------------------------------------------------------------
// Audit — append-only (enforced by trigger in migration SQL).
// ---------------------------------------------------------------------------

enum ActorType {
  USER
  SYSTEM
  INTEGRATION

  @@map("actor_type")
}

model AuditEvent {
  id             String    @id @default(uuid()) @db.Uuid
  organizationId String    @map("organization_id") @db.Uuid
  actorType      ActorType @map("actor_type")
  actorUserId    String?   @map("actor_user_id") @db.Uuid
  action         String
  resourceType   String    @map("resource_type")
  resourceId     String?   @map("resource_id")
  correlationId  String?   @map("correlation_id")
  metadata       Json      @default("{}")
  ipAddress      String?   @map("ip_address")
  createdAt      DateTime  @default(now()) @map("created_at")

  organization Organization @relation(fields: [organizationId], references: [id])

  @@index([organizationId, createdAt])
  @@index([organizationId, resourceType, resourceId])
  @@map("audit_events")
}

// ---------------------------------------------------------------------------
// Transactional outbox + PostgreSQL-backed job queue.
// ---------------------------------------------------------------------------

enum OutboxStatus {
  PENDING
  PROCESSING
  PROCESSED
  FAILED

  @@map("outbox_status")
}

model OutboxEvent {
  id             String       @id @default(uuid()) @db.Uuid
  organizationId String?      @map("organization_id") @db.Uuid
  eventType      String       @map("event_type")
  payload        Json
  status         OutboxStatus @default(PENDING)
  attempts       Int          @default(0)
  nextAttemptAt  DateTime?    @map("next_attempt_at")
  processedAt    DateTime?    @map("processed_at")
  lastError      String?      @map("last_error")
  correlationId  String?      @map("correlation_id")
  createdAt      DateTime     @default(now()) @map("created_at")

  @@index([status, nextAttemptAt])
  @@map("outbox_events")
}

enum JobStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
  CANCELED

  @@map("job_status")
}

model Job {
  id          String    @id @default(uuid()) @db.Uuid
  queue       String    @default("default")
  type        String
  payload     Json
  status      JobStatus @default(PENDING)
  priority    Int       @default(0)
  attempts    Int       @default(0)
  maxAttempts Int       @default(5) @map("max_attempts")
  runAt       DateTime  @default(now()) @map("run_at")
  lockedAt    DateTime? @map("locked_at")
  lockedBy    String?   @map("locked_by")
  lastError   String?   @map("last_error")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  @@index([queue, status, runAt, priority])
  @@map("jobs")
}

// ---------------------------------------------------------------------------
// Feature flags and idempotency.
// ---------------------------------------------------------------------------

model FeatureFlag {
  id             String   @id @default(uuid()) @db.Uuid
  key            String   @unique
  description    String?
  defaultEnabled Boolean  @default(false) @map("default_enabled")
  createdAt      DateTime @default(now()) @map("created_at")

  overrides FeatureFlagOverride[]

  @@map("feature_flags")
}

enum FlagScopeType {
  ENVIRONMENT
  ORGANIZATION
  PORTAL
  USER

  @@map("flag_scope_type")
}

model FeatureFlagOverride {
  id        String        @id @default(uuid()) @db.Uuid
  flagId    String        @map("flag_id") @db.Uuid
  scopeType FlagScopeType @map("scope_type")
  scopeId   String        @map("scope_id")
  enabled   Boolean
  createdAt DateTime      @default(now()) @map("created_at")

  flag FeatureFlag @relation(fields: [flagId], references: [id], onDelete: Cascade)

  @@unique([flagId, scopeType, scopeId])
  @@map("feature_flag_overrides")
}

// ---------------------------------------------------------------------------
// Phase 1: integrations, source objects, clients, portals, projections.
// ---------------------------------------------------------------------------

enum IntegrationProvider {
  LINEAR

  @@map("integration_provider")
}

enum ConnectionStatus {
  ACTIVE
  ERROR
  DISCONNECTED

  @@map("connection_status")
}

model IntegrationConnection {
  id                    String              @id @default(uuid()) @db.Uuid
  organizationId        String              @map("organization_id") @db.Uuid
  provider              IntegrationProvider
  status                ConnectionStatus    @default(ACTIVE)
  // "oauth" for real Linear; "fixture" for the dev/demo adapter.
  mode                  String              @default("oauth")
  workspaceId           String?             @map("workspace_id")
  workspaceName         String?             @map("workspace_name")
  // Destination team for outbound issue creation (real Linear mode).
  defaultTeamId         String?             @map("default_team_id")
  encryptedAccessToken  String?             @map("encrypted_access_token")
  encryptedRefreshToken String?             @map("encrypted_refresh_token")
  tokenExpiresAt        DateTime?           @map("token_expires_at")
  scopes                String[]            @default([])
  lastSyncAt            DateTime?           @map("last_sync_at")
  lastError             String?             @map("last_error")
  createdAt             DateTime            @default(now()) @map("created_at")
  updatedAt             DateTime            @updatedAt @map("updated_at")

  sourceObjects SourceObject[]

  @@unique([organizationId, provider])
  // One provider workspace connects to at most one organization, so webhook
  // workspace->connection resolution is deterministic. NULLs don't collide.
  @@unique([provider, workspaceId])
  @@map("integration_connections")
}

enum SourceObjectType {
  PROJECT
  ISSUE

  @@map("source_object_type")
}

model SourceObject {
  id               String              @id @default(uuid()) @db.Uuid
  organizationId   String              @map("organization_id") @db.Uuid
  connectionId     String              @map("connection_id") @db.Uuid
  provider         IntegrationProvider
  externalId       String              @map("external_id")
  type             SourceObjectType
  parentExternalId String?             @map("parent_external_id")
  title            String
  stateType        String?             @map("state_type")
  stateName        String?             @map("state_name")
  data             Json
  contentHash      String              @map("content_hash")
  archivedAt       DateTime?           @map("archived_at")
  lastSeenAt       DateTime            @default(now()) @map("last_seen_at")
  createdAt        DateTime            @default(now()) @map("created_at")
  updatedAt        DateTime            @updatedAt @map("updated_at")

  connection IntegrationConnection  @relation(fields: [connectionId], references: [id], onDelete: Cascade)
  snapshots  SourceObjectSnapshot[]
  sourceLinks SourceLink[]
  workItems  ExternalWorkItem[]

  @@unique([connectionId, externalId])
  @@index([organizationId, type])
  @@map("source_objects")
}

model SourceObjectSnapshot {
  id             String   @id @default(uuid()) @db.Uuid
  sourceObjectId String   @map("source_object_id") @db.Uuid
  data           Json
  contentHash    String   @map("content_hash")
  createdAt      DateTime @default(now()) @map("created_at")

  sourceObject SourceObject @relation(fields: [sourceObjectId], references: [id], onDelete: Cascade)

  @@index([sourceObjectId, createdAt])
  @@map("source_object_snapshots")
}

enum WebhookStatus {
  RECEIVED
  PROCESSED
  FAILED

  @@map("webhook_status")
}

// Infrastructure table (like jobs/outbox): processed by the worker across
// organizations, so not org-RLS'd.
model WebhookEvent {
  id             String              @id @default(uuid()) @db.Uuid
  organizationId String?             @map("organization_id") @db.Uuid
  provider       IntegrationProvider
  dedupeKey      String              @unique @map("dedupe_key")
  eventType      String              @map("event_type")
  payload        Json
  status         WebhookStatus       @default(RECEIVED)
  receivedAt     DateTime            @default(now()) @map("received_at")
  processedAt    DateTime?           @map("processed_at")
  lastError      String?             @map("last_error")

  @@map("webhook_events")
}

model ClientOrganization {
  id                String   @id @default(uuid()) @db.Uuid
  organizationId    String   @map("organization_id") @db.Uuid
  name              String
  slug              String
  identifierPrefix  String   @map("identifier_prefix")
  nextProjectNumber Int      @default(1) @map("next_project_number")
  nextRequestNumber Int      @default(1) @map("next_request_number")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  portals Portal[]

  @@unique([organizationId, slug])
  @@map("client_organizations")
}

model Portal {
  id                   String   @id @default(uuid()) @db.Uuid
  organizationId       String   @map("organization_id") @db.Uuid
  clientOrganizationId String   @map("client_organization_id") @db.Uuid
  name                 String
  // Globally unique: /portal/[slug] is the client-facing route identity.
  slug                 String   @unique
  // Optional per-portal override of the default internal->client status map.
  statusMapping        Json?    @map("status_mapping")
  createdAt            DateTime @default(now()) @map("created_at")
  updatedAt            DateTime @updatedAt @map("updated_at")

  clientOrganization ClientOrganization @relation(fields: [clientOrganizationId], references: [id], onDelete: Cascade)
  externalProjects   ExternalProject[]
  memberships        PortalMembership[]
  clientRequests     ClientRequest[]

  @@unique([organizationId, slug])
  // Target for the composite tenant-alignment FK from portal_memberships.
  @@unique([organizationId, id])
  @@map("portals")
}

// Client users belong to portals, never to the host organization. Their
// role (CLIENT_ADMIN/APPROVER/CONTRIBUTOR/VIEWER) lives here — separate
// from internal OrganizationMembership + ScopedRoleAssignment.
model PortalMembership {
  id             String           @id @default(uuid()) @db.Uuid
  organizationId String           @map("organization_id") @db.Uuid
  portalId       String           @map("portal_id") @db.Uuid
  userId         String           @map("user_id") @db.Uuid
  roleKey        RoleKey          @map("role_key")
  status         MembershipStatus @default(ACTIVE)
  createdAt      DateTime         @default(now()) @map("created_at")
  updatedAt      DateTime         @updatedAt @map("updated_at")

  // Composite FK: a membership's organization must be the portal's
  // organization — cross-tenant pairs are unrepresentable at the DB level.
  portal Portal @relation(fields: [organizationId, portalId], references: [organizationId, id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([portalId, userId])
  @@index([organizationId])
  @@index([userId])
  @@map("portal_memberships")
}

enum RequestType {
  FEATURE
  BUG
  CHANGE
  QUESTION
  SUPPORT
  OTHER

  @@map("request_type")
}

enum RequestStatus {
  RECEIVED
  IN_REVIEW
  ACCEPTED
  DECLINED
  CLOSED

  @@map("request_status")
}

enum ClientPriority {
  LOW
  NORMAL
  HIGH
  URGENT

  @@map("client_priority")
}

enum SyncState {
  PENDING
  SYNCED
  FAILED

  @@map("sync_state")
}

// Client requests are Frontstage-owned intake. Submission never implies a
// commitment (§27): the initial state reads "Received — Not Yet Committed".
// Client priority and internal delivery priority are separate fields, and
// Linear linkage columns are internal-only (never rendered client-side).
model ClientRequest {
  id                    String         @id @default(uuid()) @db.Uuid
  organizationId        String         @map("organization_id") @db.Uuid
  portalId              String         @map("portal_id") @db.Uuid
  identifier            String
  type                  RequestType
  title                 String
  description           String
  status                RequestStatus  @default(RECEIVED)
  clientPriority        ClientPriority @default(NORMAL) @map("client_priority")
  internalPriority      ClientPriority? @map("internal_priority")
  createdById           String         @map("created_by_id") @db.Uuid
  linearIssueId         String?        @map("linear_issue_id")
  linearIssueIdentifier String?        @map("linear_issue_identifier")
  linearSyncState       SyncState      @default(PENDING) @map("linear_sync_state")
  linearSyncError       String?        @map("linear_sync_error")
  createdAt             DateTime       @default(now()) @map("created_at")
  updatedAt             DateTime       @updatedAt @map("updated_at")

  // Decision + duplicate handling (§27).
  decisionReason       String?   @map("decision_reason")
  decidedById          String?   @map("decided_by_id") @db.Uuid
  decidedAt            DateTime? @map("decided_at")
  duplicateOfRequestId String?   @map("duplicate_of_request_id") @db.Uuid

  portal    Portal @relation(fields: [organizationId, portalId], references: [organizationId, id], onDelete: Cascade)
  createdBy User   @relation(fields: [createdById], references: [id])
  decidedBy User?  @relation("RequestDecider", fields: [decidedById], references: [id])

  // Composite tenant/portal FK: a duplicate target must live in the same
  // organization AND the same portal — cross-portal merges are
  // unrepresentable at the database level.
  duplicateOf ClientRequest?   @relation("RequestDuplicates", fields: [organizationId, portalId, duplicateOfRequestId], references: [organizationId, portalId, id], onDelete: Restrict, onUpdate: Cascade)
  duplicates  ClientRequest[]  @relation("RequestDuplicates")
  messages    RequestMessage[]

  @@unique([organizationId, identifier])
  @@unique([organizationId, id])
  @@unique([organizationId, portalId, id])
  @@index([organizationId, portalId, createdAt])
  @@map("client_requests")
}

enum RequestMessageKind {
  PUBLIC_REPLY
  INTERNAL_NOTE
  CLARIFICATION_REQUEST
  CLIENT_MESSAGE

  @@map("request_message_kind")
}

// Two-track communication (§27/§28): INTERNAL_NOTE is never reachable by
// client roles (enforced at the message leak boundary); everything else is
// the shared client-visible thread. Client-visible messages forward to the
// linked Linear issue as comments via the outbox.
model RequestMessage {
  id              String             @id @default(uuid()) @db.Uuid
  organizationId  String             @map("organization_id") @db.Uuid
  requestId       String             @map("request_id") @db.Uuid
  kind            RequestMessageKind
  body            String
  authorId        String             @map("author_id") @db.Uuid
  linearSyncState SyncState          @default(PENDING) @map("linear_sync_state")
  linearCommentId String?            @map("linear_comment_id")
  createdAt       DateTime           @default(now()) @map("created_at")

  // Composite tenant FK: a message's organization must match its request's.
  request ClientRequest @relation(fields: [organizationId, requestId], references: [organizationId, id], onDelete: Cascade)
  author  User          @relation(fields: [authorId], references: [id])

  @@index([organizationId, requestId, createdAt])
  @@map("request_messages")
}

enum ProjectionStatus {
  DRAFT
  PUBLISHED
  ARCHIVED

  @@map("projection_status")
}

model ExternalProject {
  id             String           @id @default(uuid()) @db.Uuid
  organizationId String           @map("organization_id") @db.Uuid
  portalId       String           @map("portal_id") @db.Uuid
  identifier     String
  name           String
  summary        String           @default("")
  health         String           @default("NOT_SET")
  status         ProjectionStatus @default(DRAFT)
  currentVersion Int              @default(0) @map("current_version")
  createdById    String           @map("created_by_id") @db.Uuid
  archivedAt     DateTime?        @map("archived_at")
  createdAt      DateTime         @default(now()) @map("created_at")
  updatedAt      DateTime         @updatedAt @map("updated_at")

  portal      Portal                   @relation(fields: [portalId], references: [id], onDelete: Cascade)
  sourceLinks SourceLink[]
  workItems   ExternalWorkItem[]
  versions    ExternalProjectVersion[]

  @@unique([organizationId, identifier])
  @@map("external_projects")
}

model SourceLink {
  id                String  @id @default(uuid()) @db.Uuid
  organizationId    String  @map("organization_id") @db.Uuid
  externalProjectId String  @map("external_project_id") @db.Uuid
  sourceObjectId    String  @map("source_object_id") @db.Uuid
  relationship      String?
  isPrimary         Boolean @default(false) @map("is_primary")

  externalProject ExternalProject @relation(fields: [externalProjectId], references: [id], onDelete: Cascade)
  sourceObject    SourceObject    @relation(fields: [sourceObjectId], references: [id], onDelete: Cascade)

  @@unique([externalProjectId, sourceObjectId])
  @@index([organizationId])
  @@map("source_links")
}

enum WorkItemVisibility {
  INTERNAL
  CLIENT_VISIBLE

  @@map("work_item_visibility")
}

model ExternalWorkItem {
  id                 String             @id @default(uuid()) @db.Uuid
  organizationId     String             @map("organization_id") @db.Uuid
  externalProjectId  String             @map("external_project_id") @db.Uuid
  sourceObjectId     String             @map("source_object_id") @db.Uuid
  clientTitle        String             @map("client_title")
  clientDescription  String?            @map("client_description")
  visibility         WorkItemVisibility @default(INTERNAL)
  curatedHash        String             @map("curated_hash")
  sourceChanged      Boolean            @default(false) @map("source_changed")
  archivedFromSource Boolean            @default(false) @map("archived_from_source")
  createdAt          DateTime           @default(now()) @map("created_at")
  updatedAt          DateTime           @updatedAt @map("updated_at")

  externalProject ExternalProject @relation(fields: [externalProjectId], references: [id], onDelete: Cascade)
  sourceObject    SourceObject    @relation(fields: [sourceObjectId], references: [id], onDelete: Cascade)

  @@unique([externalProjectId, sourceObjectId])
  @@index([organizationId])
  @@map("external_work_items")
}

// Immutable publication snapshots: exactly what the client saw at publish.
model ExternalProjectVersion {
  id                String   @id @default(uuid()) @db.Uuid
  organizationId    String   @map("organization_id") @db.Uuid
  externalProjectId String   @map("external_project_id") @db.Uuid
  version           Int
  snapshot          Json
  publishedById     String   @map("published_by_id") @db.Uuid
  publishedAt       DateTime @default(now()) @map("published_at")

  // Restrict, not Cascade: published snapshots are immutable client history
  // (§6.3). Removing a project means archiving it, never deleting snapshots.
  externalProject ExternalProject @relation(fields: [externalProjectId], references: [id], onDelete: Restrict)

  @@unique([externalProjectId, version])
  @@index([organizationId])
  @@map("external_project_versions")
}

model IdempotencyRecord {
  id             String   @id @default(uuid()) @db.Uuid
  organizationId String   @map("organization_id") @db.Uuid
  actorUserId    String?  @map("actor_user_id") @db.Uuid
  operation      String
  key            String
  requestHash    String   @map("request_hash")
  resultType     String?  @map("result_type")
  resultId       String?  @map("result_id")
  expiresAt      DateTime @map("expires_at")
  createdAt      DateTime @default(now()) @map("created_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, operation, key])
  @@map("idempotency_records")
}
